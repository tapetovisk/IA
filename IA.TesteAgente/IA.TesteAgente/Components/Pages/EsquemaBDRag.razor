@page "/esquema-bd-rag"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using IA.TesteAgente.Data
@using IA.TesteAgente.Servico.RAG
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<dbContext> DbFactory
@inject IServiceProvider ServiceProvider

<h3>Indexar Esquema do Banco → RAG Vetorial</h3>

<div class="row mt-3">
    <div class="col-8">

        <div class="mb-3">
            <label class="form-label">Connection String SQL Server</label>
            <input class="form-control" @bind="ConnectionString"
                   placeholder="Server=...;Database=...;User Id=...;Password=..." />
        </div>

        <div class="mb-3">
            <label class="form-label">Nome do Produto (identificador no RAG)</label>
            <input class="form-control" @bind="Produto" />
        </div>

        <button class="btn btn-primary" @onclick="IndexarAsync" disabled="@Processando">
            @(Processando ? "Processando…" : "Indexar Esquema")
        </button>

    </div>
</div>

@if (!string.IsNullOrEmpty(Mensagem))
{
    <div class="alert @(Erro ? "alert-danger" : "alert-success") mt-3">
        @Mensagem
    </div>
}

@if (Logs.Count > 0)
{
    <div class="mt-3">
        <h5>Log</h5>
        <pre style="max-height:400px; overflow-y:auto; background:#f8f9fa; padding:10px; border-radius:4px;">@string.Join("\n", Logs)</pre>
    </div>
}

@code {
    string ConnectionString { get; set; } = string.Empty;
    string Produto          { get; set; } = "EsquemaBD";
    bool   Processando      { get; set; } = false;
    bool   Erro             { get; set; } = false;
    string Mensagem         { get; set; } = string.Empty;
    List<string> Logs       { get; set; } = new();

    async Task IndexarAsync()
    {
        if (string.IsNullOrWhiteSpace(ConnectionString))
        {
            Erro      = true;
            Mensagem  = "Informe a Connection String do SQL Server.";
            return;
        }

        Processando = true;
        Erro        = false;
        Mensagem    = string.Empty;
        Logs.Clear();

        try
        {
            Logs.Add($"[{DateTime.Now:HH:mm:ss}] Iniciando leitura do esquema…");
            StateHasChanged();

            var servico = new EsquemaBDRagServico(DbFactory, ServiceProvider, ConnectionString, Produto);
            int total   = await servico.PopularRagComEsquemaAsync();

            Logs.Add($"[{DateTime.Now:HH:mm:ss}] Concluído. {total} tabela(s) indexada(s) no RAG.");
            Mensagem = $"✅ {total} tabela(s) indexada(s) com sucesso no produto '{Produto}'.";
        }
        catch (Exception ex)
        {
            Erro     = true;
            Mensagem = $"Erro: {ex.Message}";
            Logs.Add($"[{DateTime.Now:HH:mm:ss}] ERRO: {ex.Message}");
        }
        finally
        {
            Processando = false;
        }
    }
}
